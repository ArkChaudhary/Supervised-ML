# Evaluation

### Using sklearn library "metrics"
metrics_df

accuracy_scores = []
precision_scores = []
recall_scores = []
mean_squared_errors = []

for model_name, index in models.items():
    prediction = predictions[index]

    if prediction is None:
        accuracy_scores.append(None)
        precision_scores.append(None)
        recall_scores.append(None)
        mean_squared_errors.append(None)
        continue

    try:
        accuracy = accuracy_score(y_test, prediction)
    except ValueError:
        accuracy = None

    try:
        precision = precision_score(y_test, prediction)
    except ValueError:
        precision = None

    try:
        recall = recall_score(y_test, prediction)
    except ValueError:
        recall = None

    try:
        mse = mean_squared_error(y_test, prediction)
    except (ValueError, TypeError):
        mse = None

    accuracy_scores.append(accuracy)
    precision_scores.append(precision)
    recall_scores.append(recall)
    mean_squared_errors.append(mse)

data = {
    "Model": models.keys(),
    "Accuracy": accuracy_scores,
    "Precision": precision_scores,
    "Recall": recall_scores,
    "MSE": mean_squared_errors,
 }

Result_table = pd.DataFrame(data)

Result_table

